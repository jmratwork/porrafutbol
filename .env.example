# Cadena de conexión a PostgreSQL (Vercel Postgres / Neon / Supabase / cualquier Postgres).
# Ejemplo Neon:   postgresql://usuario:password@ep-xxxx.eu-central-1.aws.neon.tech/porra?sslmode=require
# Ejemplo local:  postgresql://postgres:postgres@localhost:5432/porra?schema=public
DATABASE_URL="postgresql://usuario:password@host:5432/porra?sslmode=require"

# PIN de administración: protege /admin y las mutaciones de la API.
# En producción debe tener AL MENOS 12 caracteres (idealmente aleatorio); si es más
# corto, las operaciones de administración quedan bloqueadas. Usa una cadena larga.
ADMIN_PIN="cambia-esto-por-un-pin-largo-y-aleatorio"

# Secreto (pepper) para los códigos de cada apuesta. Cualquier cadena larga y aleatoria.
# OBLIGATORIO en producción: si falta, el servidor aborta en vez de usar un valor por
# defecto público (que permitiría falsificar códigos con un volcado de la base de datos).
APUESTA_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria"

# (Opcional) Almacén KV para el rate-limiting persistente anti-fuerza-bruta.
# Si lo conectas en Vercel (Storage → Upstash Redis / Vercel KV), estas variables se
# inyectan solas y el límite pasa a compartirse entre instancias. Si no, se usa un
# limitador en memoria por instancia (funciona, pero no resiste cold starts).
# Se aceptan tanto las de Vercel KV (KV_REST_API_*) como las de Upstash (UPSTASH_REDIS_REST_*).
# KV_REST_API_URL="https://xxxx.upstash.io"
# KV_REST_API_TOKEN="xxxxx"
